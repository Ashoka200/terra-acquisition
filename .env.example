# Copy to .env for local prod testing, or set these as Railway service Variables.

# Data directory — on Railway, mount a Volume here and set this to its path.
RE_DATA=/app/data

# Flask session signing secret — REQUIRED in production. Generate a random 32+ char string.
SECRET_KEY=change-me-to-a-long-random-string

# --- Authentication (optional; off by default so the app is open) ---
# Turn on sign-in + the security firewall:
AUTH_ENABLED=1
# Bootstrap admin(s): these emails get auto-approved as Admin on sign-up/sign-in.
ADMIN_EMAILS=AshokR@unitedbrothersnv.com
# Temporary admin password for first sign-in (then create real users):
ADMIN_PASSWORD=change-me

# --- ATLAS copilot (optional) ---
# Without a key, ATLAS runs in offline rule-based mode (tools still work).
# ANTHROPIC_API_KEY=sk-ant-...
# ATLAS_MODEL=claude-opus-4-8
